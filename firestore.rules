rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // All resources - public read, admin write
    match /RESOURCES_STUDYPEDIA/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
    }
    
    // User payments
    match /user_payments/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId 
                  || request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
      allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
    }
    
    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
