rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read courses (top-level collection)
    match /RESOURCES_STUDYPEDIA/{courseId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@studypedia.ug';
      
      // Allow authenticated users to read semesters, course_units, documents
      match /semesters/{semesterId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.email == 'admin@studypedia.ug';
      }
      
      match /course_units/{unitId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.email == 'admin@studypedia.ug';
      }
      
      match /documents/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.email == 'admin@studypedia.ug';
      }
    }
    
    // User payments - users can read their own, admin can read all
    match /user_payments/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId 
                  || request.auth.token.email == 'admin@studypedia.ug';
      allow write: if request.auth != null && request.auth.token.email == 'admin@studypedia.ug';
    }
    
    // Allow authenticated users to read their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
