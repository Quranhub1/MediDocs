rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== STUDYPEDIA RULES (Authentication Required) ==========
    // RESOURCES_STUDYPEDIA/{courseId}/semesters/{semesterId}/courseunits/{unitId}/documents/{docId}
    match /RESOURCES_STUDYPEDIA/{courseId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
      
      match /semesters/{semesterId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
        
        match /courseunits/{unitId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
          
          match /documents/{docId} {
            allow read: if request.auth != null;
            allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
          }
        }
        
        match /documents/{docId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
        }
      }
    }
    
    // ========== MEDIDOCS RULES (Public Read Access) ==========
    // RESOURCES_MEDIDOCS/{courseId}/semesters/{semesterId}/courseunits/{unitId}/documents/{docId}
    match /RESOURCES_MEDIDOCS/{courseId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
      
      match /semesters/{semesterId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
        
        match /courseunits/{unitId} {
          allow read: if true;
          allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
          
          match /documents/{docId} {
            allow read: if true;
            allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
          }
        }
        
        match /documents/{docId} {
          allow read: if true;
          allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
        }
      }
    }
    
    // User payments
    match /user_payments/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId 
                  || request.auth.token.email == 'kaigwaakram123@gmail.com';
      allow write: if request.auth != null && request.auth.token.email == 'kaigwaakram123@gmail.com';
    }
    
    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
