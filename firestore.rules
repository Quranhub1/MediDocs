rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read public documents
    match /public/{documentId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Resources collection - study materials for students
    match /RESOURCES_STUDYPEDIA/{documentId} {
      allow read: if true;  // Public for all users
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // User profiles - users can read/write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User chat messages - only the user can read/write their own messages
    match /chats/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents/Courses (legacy support)
    match /documents/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
