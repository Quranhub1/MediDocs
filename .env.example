# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://yourusername.github.io,http://localhost:5173
ALLOWED_ORIGINS=https://yourusername.github.io,http://localhost:3000

# ─── Groq AI API ──────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Download your service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then copy each field below from that JSON file.

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
# Keep the quotes and \n characters exactly as they appear in the JSON file
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
